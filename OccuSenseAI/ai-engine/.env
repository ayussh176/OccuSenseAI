# ============================================================
# OccuSense AI — Environment Variables
# ============================================================
# Copy this file to .env and customize for your environment.
# ============================================================

# ── General ──────────────────────────────────────────────────
APP_NAME=OccuSense AI
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── FastAPI ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
CORS_ORIGINS=*

# ── Simulation ───────────────────────────────────────────────
SIMULATION_MODE=true
SIMULATION_INTERVAL_SECONDS=5.0
NUM_ZONES=4

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=occusense
POSTGRES_PASSWORD=occusense
POSTGRES_DB=occusense
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# ── InfluxDB ─────────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=my-super-secret-token
INFLUX_ORG=occusense
INFLUX_BUCKET=sensor_data

# ── MQTT ─────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=occusense-backend
MQTT_TOPIC_PREFIX=building/zone

# ── LLM (Phase 3+) ──────────────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
LLM_PROVIDER=mock
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.4

# ── RL Engine (Phase 3+) ────────────────────────────────────
RL_MODEL_PATH=models/ppo_hvac_agent.zip

# ── Automation ───────────────────────────────────────────────
ALERT_CO2_WARNING=1000
ALERT_CO2_CRITICAL=1500
COMFORT_TEMP_MIN=21.0
COMFORT_TEMP_MAX=25.0

# ── WebSocket ────────────────────────────────────────────────
WS_BROADCAST_INTERVAL_SECONDS=3.0
WS_MAX_CONNECTIONS=100
